# LaTeX build artifacts
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.bbl
*.blg
*.pdfsync

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Fonts (too large for git, download from original repos)

# === resume 目录内容不跟踪(含个人信息,公开仓库不提交)===
# 目录结构保留(通过 .gitkeep),但里面所有文件 gitignore。
# 本地 resume/ 照常使用(含完整信息),远程只看到空目录结构。
resume/**
!resume/.gitkeep

# CLAUDE.md（AI 开发上下文文档，含本地路径/个人背景，不入公开仓库）
# 本地保留，远程移除。
CLAUDE.md
**/CLAUDE.md

# docs/（设计文档与实现计划，开发私用，不入公开仓库）
# 本地保留，远程移除。
docs/

# ZCode 本地配置/计划（工具产物，不入库）
.zcode/

# Resume build output (历史保留,已被上面规则覆盖)

# Skill-tree generated artifacts (regenerate with: python skill-tree/tools/render.py)
skill-tree/dist/

# Frontend (React/Vite)
skill-tree/frontend/node_modules/
skill-tree/frontend/dist/
skill-tree/frontend/tsconfig.tsbuildinfo
skill-tree/frontend/*.tsbuildinfo

# Backend (FastAPI)
skill-tree/backend/__pycache__/
skill-tree/backend/*.pyc

# Per-user LLM API keys (NEVER commit) — contains api_key secrets
skill-tree/data/llm_config.json

# 实测脚本本地配置(含 api_key,绝不入库)+ 实测产物
eval/config.local.json
eval/results/
eval/rag_index_test/
eval/*.png

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Large model/data files
*.bin
*.pt
*.pth
*.h5
*.hdf5
*.ckpt
*.safetensors
datasets/

# === 桌面应用打包(Tauri + PyInstaller)===
# PyInstaller 后端冻结产物(build-desktop.sh 生成)
skill-tree/backend/build/
skill-tree/backend/dist/
skill-tree/backend/*.spec.bak
# Tauri 构建产物(每个 src-tauri 内已有 .gitignore 覆盖 target/,这里兜底)
skill-tree/desktop/src-tauri/target/
# sidecar 复制进 src-tauri 的产物(不入库,打包时生成)
skill-tree/desktop/src-tauri/sidecar/
# lark-cli 二进制(打包时复制,不入库)
skill-tree/desktop/src-tauri/resources/lark-cli
skill-tree/desktop/src-tauri/resources/lark-cli.exe
# 图标二进制(可选;占位图标不入库,用 cargo tauri icon 重新生成)
skill-tree/desktop/src-tauri/icons/*.ico
skill-tree/desktop/src-tauri/icons/*.icns
skill-tree/desktop/src-tauri/icons/*.png

# === 运行时数据(用户-specific,不入库)===
skill-tree/data/chat_history.json
skill-tree/data/rag_index/
# 桌面应用用户主目录数据(若打包后在开发机跑过)
~/.skill-tree/


# 导出的对话会话(chat export,临时数据,不入库)
skill-tree/*学习方向*.json
skill-tree/data/export_*.json
