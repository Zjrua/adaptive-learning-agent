{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "Skill Tree",
  "version": "0.1.0",
  "identifier": "com.zjrua.skilltree",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "技能树",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "resources/lark-cli.exe": "lark-cli.exe",
      "sidecar/skill-tree-backend.exe": "sidecar/skill-tree-backend.exe",
      "sidecar/_internal": "sidecar/_internal"
    },
    "externalBin": []
  }
}
